{
  "name": "todo-with-obsidian",
  "version": "0.2.1",
  "description": "할 일을 만들고 완료를 체크하면 날짜별 Daily Note에 자동으로 기록하는 Obsidian 플러그인",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production"
  },
  "keywords": ["obsidian", "todo", "tasks", "daily-notes"],
  "author": "HAKJU MUN",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.20.0",
    "obsidian": "latest",
    "tslib": "^2.6.2",
    "typescript": "^5.4.0"
  }
}
